# ── LearnHouse Production Environment Variables ────────────────────────
# Copy to .env and fill in values before running docker compose up.

# === Database ===
LEARNHOUSE_SQL_CONNECTION_TYPE=postgresql
LEARNHOUSE_SQL_CONNECTION_STRING=postgresql+asyncpg://learnhouse:CHANGE_ME@db:5432/learnhouse

# === Redis ===
LEARNHOUSE_REDIS_CONNECTION_STRING=redis://redis:6379/learnhouse

# === Security ===
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
LEARNHOUSE_AUTH_JWT_SECRET_KEY=

# === Hosting ===
LEARNHOUSE_SITE_NAME=LearnHouse
LEARNHOUSE_DOMAIN=learnhouse.example.com
LEARNHOUSE_FRONTEND_DOMAIN=learnhouse.example.com
LEARNHOUSE_PORT=9000
LEARNHOUSE_TENANCY=single
LEARNHOUSE_SSL=true
LEARNHOUSE_DEVELOPMENT_MODE=false
LEARNHOUSE_ALLOWED_ORIGINS=https://learnhouse.example.com

# === S3 Storage (optional — omit or leave blank for local filesystem) ===
# LEARNHOUSE_CONTENT_DELIVERY_TYPE=s3api
# LEARNHOUSE_S3_API_BUCKET_NAME=learnhouse-media
# LEARNHOUSE_S3_API_ENDPOINT_URL=https://s3.eu-west-1.amazonaws.com
# LEARNHOUSE_S3_API_REGION=eu-west-1
# LEARNHOUSE_S3_API_ACCESS_KEY_ID=
# LEARNHOUSE_S3_API_SECRET_ACCESS_KEY=

# === Mail ===
LEARNHOUSE_EMAIL_PROVIDER=resend
LEARNHOUSE_SYSTEM_EMAIL_ADDRESS=noreply@learnhouse.example.com
LEARNHOUSE_RESEND_API_KEY=

# === AI (optional) ===
# LEARNHOUSE_OPENAI_API_KEY=
# LEARNHOUSE_GEMINI_API_KEY=

# === Sentry (optional) ===
# LEARNHOUSE_SENTRY_DSN=

# === Logging & Observability ===
LEARNHOUSE_LOG_LEVEL=INFO
LEARNHOUSE_LOG_FORMAT=json           # "json" or "text" — structured JSON logs in production

# === OpenTelemetry (optional) ===
# LEARNHOUSE_OTEL_ENABLED=true
# LEARNHOUSE_OTEL_SERVICE_NAME=learnhouse-api
# LEARNHOUSE_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# LEARNHOUSE_OTEL_EXPORTER_OTLP_HEADERS=x-api-key=your_key_here

# === Slow Query Threshold (milliseconds, default 500) ===
# LEARNHOUSE_SLOW_QUERY_THRESHOLD_MS=500

# === Backup (optional — if unset, backup scripts use defaults) ===
# LEARNHOUSE_BACKUP_DIR=/home/learnhouse/app/backups
# LEARNHOUSE_BACKUP_RETENTION_DAYS=30
# LEARNHOUSE_BACKUP_S3_DEST=s3://my-bucket/learnhouse-backups/
# LEARNHOUSE_BACKUP_CORS_ORIGIN=https://learnhouse.example.com

# === Postgres (Docker only — not used by app directly) ===
POSTGRES_USER=learnhouse
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=learnhouse

# === Redis (Docker only — not used by app directly) ===
REDIS_PASSWORD=
